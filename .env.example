# Copy to .env and fill in values
API_KEY=your-secret-api-key-here
API_KEY_NAME=X-API-Key

# Storage
UPLOAD_DIR=/app/data/uploads
OUTPUT_DIR=/app/data/outputs
MODELS_DIR=/root/models
LOG_DIR=/app/data/logs

# MinerU settings
MINERU_DEVICE=cuda
MINERU_LANG=auto
MINERU_FORCE_OCR=true
MINERU_BACKEND=hybrid
MINERU_EFFORT=high

# Parallelism — L4 46GB: 2 safe, bump to 3 only after VRAM profiling
PARALLEL_WORKERS=3
CUDA_MPS_ENABLE=true

# Server
HOST=0.0.0.0
PORT=8000
MAX_UPLOAD_MB=500
JOB_TTL_SECONDS=3600
